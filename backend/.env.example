# ──────────────────────────────────────────────────────────────────────────────
# KokoMusic Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ──────────────────────────────────────────────────────────────────────────────

# Puerto del servidor (por defecto 3001)
PORT=3001

# ── Spotify API ────────────────────────────────────────────────────────────────
# Obtén tus credenciales en: https://developer.spotify.com/dashboard
# → Create App → Client ID / Client Secret
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback
FRONTEND_URI=http://localhost:5173

# ── Audio Cache ───────────────────────────────────────────────────────────────
AUDIO_DIR=./audio_cache

# ── Audio Encoding ───────────────────────────────────────────────────────────
AUDIO_BITRATE=96k
AUDIO_VBR=true
AUDIO_COMPRESSION_LEVEL=10
AUDIO_SAMPLE_RATE=48000

# ── CORS ──────────────────────────────────────────────────────────────────────
# En modo local, agregar también la URL del túnel de Cloudflare si la conoces.
# Acepta múltiples orígenes separados por coma.
# Ejemplo: http://localhost:5173,https://tu-tunel.trycloudflare.com
CORS_ORIGIN=http://localhost:5173

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────────────────
# Service role key: bypassa RLS para escrituras desde el backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ──  TicketMaster ─────────────────────────────────────────────────────────────
TICKETMASTER_KEY=your_ticketmaster_api_key

# ──  Last.fm ──────────────────────────────────────────────────────────────────
LASTFM_KEY=your_lastfm_api_key

# ── Cloudflare R2 CDN ─────────────────────────────────────────────────────────
# Opcional — si no se configura, el CDN queda desactivado y se usa cache local
CF_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=kokomusic1
R2_CDN_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

CDN_MAX_FILE_MB=30
CDN_BUCKET_CAPACITY_MB=10240
CDN_REQUEST_WARN=800000
CDN_STORAGE_WARN_MB=8192
